# ─────────────────────────────────────────────────────────────────────────────
# CTS BPO — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
APP_URL=https://your-app-url.railway.app   # Set to your deployed domain

# ── Database (Supabase PostgreSQL) ───────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string-min-32-chars
ADMIN_EMAIL=admin@ctsbpo.com
ADMIN_PASSWORD=YourSecurePassword

# ── Email Providers (use at least one) ───────────────────────────────────────
# Brevo (primary — 300 free emails/day): https://app.brevo.com → API Keys
BREVO_API_KEY=

# MailerLite (second — 399 free emails/day): https://app.mailerlite.com → API
MAILERLITE_API_KEY=

# Gmail App Password (backup — 200/day cold email cap)
# Enable 2FA on Gmail, then: Google Account → Security → App Passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Gmail OAuth2 (optional — more reliable than App Password)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ── Google APIs ──────────────────────────────────────────────────────────────
# Google Cloud Console: https://console.cloud.google.com
GOOGLE_API_KEY=              # Places API + Gemini AI (free tier)
GOOGLE_CSE_ID=               # Custom Search Engine ID: https://cse.google.com
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCAI_PROCESSOR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON= # JSON content of service account key (single line)

# ── Lead Generation ──────────────────────────────────────────────────────────
# SerpAPI (100 free searches/month): https://serpapi.com
SERPAPI_KEY=

# Freelancer.com API token (auto-bidder)
FREELANCER_TOKEN=

# ── Payments ─────────────────────────────────────────────────────────────────
# PayPal: https://developer.paypal.com
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Ozow (South African payment gateway — contact Ozow for activation)
OZOW_API_KEY=
OZOW_PRIVATE_KEY=
OZOW_SITE_CODE=

# ── Optional: Twilio WhatsApp notifications ───────────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
